# Scanner service ---------------------------------------------------------
PORT=8080

# Primary lightwalletd endpoint. Fallbacks are compiled in.
LIGHTWALLETD_URL=https://zec.rocks:443

# Directory the ephemeral scan wallet is written to, then wiped after each job.
# Must be writable and must NOT be a persisted volume.
SCAN_WALLET_DIR=/tmp/turnstile-scan

# Hard cap on how many blocks a single scan will walk before giving up.
SCAN_DEPTH_CAP_BLOCKS=500000

# Alert watcher (F4) ------------------------------------------------------
# The server-owned unified address users send their TURNSTILE:SUB memo to.
# Shown on /alerts and encoded into the ZIP-321 QR. Holds dust only.
TURNSTILE_UNIFIED_ADDRESS=

# The VIEWING key for that same address, and its birthday height. The watcher
# needs only to *read* the incoming memos, so a full viewing key is all it gets
# — the server cannot spend the dust it is sent, by construction. Leave unset
# and the watcher disables itself; the rest of the tool works normally.
TURNSTILE_UFVK=
TURNSTILE_BIRTHDAY=

# Anonymous push. No accounts, no PII.
NTFY_BASE_URL=https://ntfy.sh

# Frontend ----------------------------------------------------------------
# Where the Next.js app proxies /api/scan to. Server-only on purpose: a
# NEXT_PUBLIC_ prefix would ship the scanner's address into the browser bundle,
# and the browser must never talk to the scanner directly — /api/scan is what
# enforces the per-IP rate limit and the spending-key refusal.
SCANNER_URL=http://localhost:8080

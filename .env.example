# Scanner service ---------------------------------------------------------
PORT=8080

# Primary lightwalletd endpoint. Fallbacks are compiled in.
LIGHTWALLETD_URL=https://zec.rocks:443

# Directory the ephemeral scan wallet is written to, then wiped after each job.
# Must be writable and must NOT be a persisted volume.
SCAN_WALLET_DIR=/tmp/turnstile-scan

# Hard cap on how many blocks a single scan will walk before giving up.
SCAN_DEPTH_CAP_BLOCKS=500000

# Alert watcher (F4) ------------------------------------------------------
# The server-owned unified address users send their TURNSTILE:SUB memo to.
# Holds dust-level funds only.
TURNSTILE_UNIFIED_ADDRESS=

# Anonymous push. No accounts, no PII.
NTFY_BASE_URL=https://ntfy.sh

# Frontend ----------------------------------------------------------------
# Where the Next.js app proxies /api/scan to.
NEXT_PUBLIC_SCANNER_URL=http://localhost:8080
